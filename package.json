{
  "name": "@primitives-ui/monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "",
  "keywords": [],
  "license": "MIT",
  "author": "X1ng Yu",
  "type": "module",
  "scripts": {
    "dev:sb": "pnpm --filter='./apps/storybook' dev",
    "build:packages": "turbo build --filter='./packages/*'",
    "lint": "oxlint -c ./.oxlintrc.json",
    "lint:fix": "pnpm lint --fix",
    "format": "oxfmt -c ./.oxfmtrc.json",
    "format:check": "pnpm format --check",
    "format:fix": "pnpm format --write",
    "prepublish:packages": "pnpm build:packages",
    "publish:packages": "pnpm --filter @primitives-ui/utils publish --access public && pnpm --filter @primitives-ui/react publish --access public",
    "typecheck": "turbo typecheck",
    "test": "VITEST_ENV=chromium vitest run",
    "test:jsdom": "vitest run --project '*:jsdom'",
    "test:chromium": "VITEST_ENV=chromium vitest run --project '*:browser'",
    "test:firefox": "VITEST_ENV=firefox vitest run --project '*:browser'",
    "test:webkit": "VITEST_ENV=webkit vitest run --project '*:browser'",
    "test:browsers": "VITEST_ENV=all-browsers vitest run --project '*:browser'",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@testing-library/jest-dom": "6.9.1",
    "@types/node": "25.9.0",
    "@vitest/browser-playwright": "4.1.6",
    "@vitest/coverage-istanbul": "4.1.6",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.4",
    "oxfmt": "0.49.0",
    "oxlint": "1.64.0",
    "oxlint-tsgolint": "0.22.1",
    "playwright": "1.60.0",
    "tsdown": "0.22.0",
    "turbo": "latest",
    "typescript": "6.0.3",
    "vite": "8.0.12",
    "vitest": "4.1.6"
  },
  "engines": {
    "node": ">=22.22.2",
    "pnpm": "10.29.2"
  },
  "packageManager": "pnpm@10.29.2"
}
