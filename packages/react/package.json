{
  "name": "@primitives-ui/react",
  "version": "0.0.0",
  "private": false,
  "keywords": [
    "react",
    "react-component"
  ],
  "license": "MIT",
  "author": "X1ng Yu",
  "repository": {
    "type": "git",
    "url": "https://github.com/rxy001/primitives-ui.git",
    "directory": "packages/react"
  },
  "files": [
    "build",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./button": "./src/button/index.ts",
    "./command": "./src/command/index.ts",
    "./collapsible": "./src/collapsible/index.ts",
    "./collection": "./src/collection/index.ts",
    "./accordion": "./src/accordion/index.ts"
  },
  "publishConfig": {
    "main": "./build/index.js",
    "types": "./build/index.d.ts",
    "exports": {
      ".": {
        "types": "./build/index.d.ts",
        "import": "./build/index.js"
      },
      "./button": {
        "types": "./build/button/index.d.ts",
        "import": "./build/button/index.js"
      },
      "./command": {
        "types": "./build/command/index.d.ts",
        "import": "./build/command/index.js"
      },
      "./collapsible": {
        "types": "./build/collapsible/index.d.ts",
        "import": "./build/collapsible/index.js"
      },
      "./collection": {
        "types": "./build/collection/index.d.ts",
        "import": "./build/collection/index.js"
      },
      "./accordion": {
        "types": "./build/accordion/index.d.ts",
        "import": "./build/accordion/index.js"
      }
    }
  },
  "scripts": {
    "typecheck": "tsc -noEmit",
    "build": "node ../../scripts/build.ts"
  },
  "dependencies": {
    "@primitives-ui/utils": "workspace:*",
    "clsx": "2.1.1"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "react": "catalog:",
    "react-dom": "catalog:",
    "vitest-browser-react": "2.2.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
