{
  "name": "@primitives-ui/monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "",
  "keywords": [],
  "license": "MIT",
  "author": "X1ng Yu",
  "type": "module",
  "scripts": {
    "dev:sb": "turbo dev --filter='./apps/storybook'",
    "build:packages": "turbo build --filter='./packages/*'",
    "lint": "oxlint -c ./.oxlintrc.json",
    "lint:fix": "pnpm lint --fix",
    "format": "oxfmt -c ./.oxfmtrc.json",
    "format:check": "pnpm format --check",
    "format:fix": "pnpm format --write",
    "prepare:publish": "node scripts/resolve-workspace-dependencies.ts",
    "prepublish:packages": "pnpm build:packages && pnpm prepare:publish",
    "publish:packages": "pnpm publish packages/utils/build --access public --no-git-checks && pnpm publish packages/react/build --access public --no-git-checks",
    "publish": "pnpm publish:packages",
    "typecheck": "turbo typecheck",
    "test": "pnpm test:jsdom && pnpm test:browsers",
    "test:unit": "vitest run --project @primitives-ui/react --project @primitives-ui/utils",
    "test:jsdom": "VITEST_ENV=jsdom pnpm test:unit",
    "test:chromium": "VITEST_ENV=chromium pnpm test:unit",
    "test:firefox": "VITEST_ENV=firefox pnpm test:unit",
    "test:webkit": "VITEST_ENV=webkit pnpm test:unit",
    "test:browsers": "VITEST_ENV=all-browsers pnpm test:unit",
    "test:coverage": "pnpm test:jsdom --coverage && pnpm test:chromium --coverage",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@testing-library/jest-dom": "6.9.1",
    "@types/node": "25.9.0",
    "@vitest/browser-playwright": "4.1.6",
    "@vitest/coverage-istanbul": "4.1.6",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.4",
    "oxfmt": "0.49.0",
    "oxlint": "1.64.0",
    "oxlint-tsgolint": "0.22.1",
    "playwright": "1.60.0",
    "tsdown": "0.22.0",
    "turbo": "latest",
    "typescript": "6.0.3",
    "vite": "8.0.12",
    "vitest": "4.1.6"
  },
  "engines": {
    "node": ">=22.22.2",
    "pnpm": "10.29.2"
  },
  "packageManager": "pnpm@10.29.2"
}
