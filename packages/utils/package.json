{
  "name": "@primitives-ui/utils",
  "version": "0.0.0",
  "private": false,
  "keywords": [],
  "license": "MIT",
  "author": "X1ng Yu",
  "repository": {
    "type": "git",
    "url": "https://github.com/rxy001/primitives-ui.git",
    "directory": "packages/utils"
  },
  "files": [
    "build",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./addEventListener": "./src/addEventListener.ts",
    "./createContext": "./src/createContext.ts",
    "./env": "./src/env.ts",
    "./is": "./src/is.ts",
    "./mergeProps": "./src/mergeProps.ts",
    "./mergeRefs": "./src/mergeRefs.ts",
    "./ownerDocument": "./src/ownerDocument.ts",
    "./ownerWindow": "./src/ownerWindow.ts"
  },
  "publishConfig": {
    "main": "./build/index.js",
    "types": "./build/index.d.ts",
    "exports": {
      ".": {
        "types": "./build/index.d.ts",
        "import": "./build/index.js"
      },
      "./addEventListener": {
        "types": "./build/addEventListener.d.ts",
        "import": "./build/addEventListener.js"
      },
      "./createContext": {
        "types": "./build/createContext.d.ts",
        "import": "./build/createContext.js"
      },
      "./env": {
        "types": "./build/env.d.ts",
        "import": "./build/env.js"
      },
      "./is": {
        "types": "./build/is.d.ts",
        "import": "./build/is.js"
      },
      "./mergeProps": {
        "types": "./build/mergeProps.d.ts",
        "import": "./build/mergeProps.js"
      },
      "./mergeRefs": {
        "types": "./build/mergeRefs.d.ts",
        "import": "./build/mergeRefs.js"
      },
      "./ownerDocument": {
        "types": "./build/ownerDocument.d.ts",
        "import": "./build/ownerDocument.js"
      },
      "./ownerWindow": {
        "types": "./build/ownerWindow.d.ts",
        "import": "./build/ownerWindow.js"
      }
    }
  },
  "scripts": {
    "typecheck": "tsc -noEmit",
    "build": "node ../../scripts/build.ts"
  },
  "devDependencies": {
    "@types/react": "catalog:dev",
    "@types/react-dom": "catalog:dev",
    "react": "catalog:dev",
    "react-dom": "catalog:dev"
  },
  "peerDependencies": {
    "react": "catalog:peer",
    "react-dom": "catalog:peer"
  }
}
